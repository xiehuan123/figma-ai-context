{
  "name": "figma-ai-context",
  "version": "1.3.1",
  "description": "Figma MCP Server - 将 Figma API 数据处理成 AI 友好格式",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "figma-ai-context": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:patch": "npm version patch && git push origin master --tags",
    "release:minor": "npm version minor && git push origin master --tags",
    "release:major": "npm version major && git push origin master --tags"
  },
  "keywords": [
    "figma",
    "mcp",
    "model-context-protocol",
    "ai",
    "design"
  ],
  "author": "xiehuan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiehuan123/figma-ai-context.git"
  },
  "homepage": "https://github.com/xiehuan123/figma-ai-context#readme",
  "bugs": {
    "url": "https://github.com/xiehuan123/figma-ai-context/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
